{
  "manifest_version": 3,
  "name": "简历魔方——简历定制助手",
  "version": "1.1.0",
  "description": "简历魔方 - 支持BOSS直聘/智联/猎聘/前程无忧/应届生求职网，一键抓取JD，AI生成定制简历，导出PDF",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.zhipin.com/*",
    "https://*.zhaopin.com/*",
    "https://*.liepin.com/*",
    "https://*.51job.com/*",
    "https://*.yingjiesheng.com/*",
    "https://api.deepseek.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/*",
        "https://*.zhaopin.com/*",
        "https://*.liepin.com/*",
        "https://*.51job.com/*",
        "https://*.yingjiesheng.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
